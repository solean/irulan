{
  "name": "irulan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n server,web -c cyan,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "bunx --bun vite",
    "build": "bunx --bun vite build && bunx --bun esbuild src/server/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/server/index.cjs --external:sql.js && bunx tsc --noEmit",
    "check": "bunx tsc --noEmit",
    "start": "NODE_ENV=production node dist/server/index.cjs",
    "electron": "bun run build && electron .",
    "electron:pack": "bun run build && electron-builder --mac dir",
    "electron:dist": "bun run build && electron-builder --mac",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.5.11",
    "hono": "^4.12.12",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "nodemailer": "^8.0.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "shadcn": "^4.3.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "build": {
    "appId": "dev.cschnabel.irulan",
    "productName": "Irulan",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
