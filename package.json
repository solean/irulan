{
  "name": "irulan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c cyan,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun --hot src/server/index.ts",
    "dev:web": "bunx --bun vite",
    "build": "bunx --bun vite build && bunx tsc --noEmit",
    "check": "bunx tsc --noEmit",
    "start": "NODE_ENV=production bun src/server/index.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.5.11",
    "hono": "^4.12.12",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.12",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
